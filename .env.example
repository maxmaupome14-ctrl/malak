# =====================================================
# Malak AI — Environment Configuration
# =====================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =====================================================

# ── General ──────────────────────────────────────────
# Application environment: development | staging | production
APP_ENV=development

# Secret key for signing JWTs and encrypting sessions
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-random-64-char-string

# Base URL where the API is accessible (used for CORS and callbacks)
API_URL=http://localhost:8000

# Base URL where the frontend is accessible
WEB_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────
# PostgreSQL connection string (async driver)
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://malak:malak@localhost:5432/malak

# ── Valkey / Redis ───────────────────────────────────
# Used for task queue (arq) and caching
VALKEY_URL=redis://localhost:6379/0

# ── AI / LLM ────────────────────────────────────────
# OpenAI API key — used by agents for analysis and copywriting
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Model to use for agent reasoning (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# Optional: Anthropic API key (for Claude-based agents)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Custom OpenAI-compatible endpoint (e.g., Ollama, vLLM, LiteLLM)
# OPENAI_BASE_URL=http://localhost:11434/v1

# ── Scraping ─────────────────────────────────────────
# Playwright browser to use: chromium | firefox | webkit
BROWSER_TYPE=chromium

# Whether to run the browser in headless mode (true for production)
BROWSER_HEADLESS=true

# Optional: Proxy URL for scraping (rotating proxies recommended for production)
# PROXY_URL=http://user:pass@proxy-host:port

# Optional: ScraperAPI key (fallback for anti-bot protected sites)
# SCRAPERAPI_KEY=your-scraperapi-key

# ── Auth ─────────────────────────────────────────────
# JWT token lifetime in seconds (default: 3600 = 1 hour)
JWT_LIFETIME_SECONDS=3600

# Allow user registration (set to false to restrict access)
ALLOW_REGISTRATION=true

# ── Email (Optional) ────────────────────────────────
# SMTP configuration for password reset and notifications
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# FROM_EMAIL=noreply@malak.ai

# ── Monitoring (Optional) ───────────────────────────
# Sentry DSN for error tracking
# SENTRY_DSN=https://your-sentry-dsn

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
